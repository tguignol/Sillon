    "Téléchargez un morceau ou un album depuis la bibliothèque pour le retrouver ici, et l'écouter hors connexion." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lade einen Titel oder ein Album aus der Bibliothek herunter, um es hier wiederzufinden und offline zu hören."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Download a track or album from the library to find it here and listen offline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descarga una pista o un álbum desde la biblioteca para encontrarlo aquí y escucharlo sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Téléchargez un morceau ou un album depuis la bibliothèque pour le retrouver ici, et l'écouter hors connexion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scarica un brano o un album dalla libreria per ritrovarlo qui e ascoltarlo offline."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transfira uma música ou um álbum a partir da biblioteca para o encontrar aqui e o ouvir offline."
          }
        },
        "rm" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Telechargiai ina chanzun u in album ord la biblioteca per al chattar qua e tadlar offline."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shkarko një këngë ose album nga biblioteka për ta gjetur këtu dhe për ta dëgjuar pa internet."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preuzmite pesmu ili album iz biblioteke da biste ih ovde pronašli i slušali van mreže."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Burada görmek ve çevrimdışı dinlemek için kitaplıktan bir parça veya albüm indirin."
          }
        }
      }
    },
