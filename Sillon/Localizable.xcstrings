    "Touchez le cœur sur un artiste, un album ou un titre pour le retrouver ici.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf das Herz bei einem Interpreten, Album oder Titel, um ihn hier wiederzufinden."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca il cuore su un artista, un album o un brano per ritrovarlo qui."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the heart on an artist, album or track to find it here."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque no coração num artista, álbum ou faixa para o encontrar aqui."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Prek zemrën te një artist, album ose këngë për ta gjetur këtu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el corazón en un artista, un álbum o una pista para encontrarlo aquí."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodirnite srce na izvođaču, albumu ili pesmi da biste ih ovde pronašli."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Smacchai sin il cor tar in artist, in album u in toc per al chattar qua."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir sanatçı, albüm veya parçayı burada görmek için kalbe dokunun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez le cœur sur un artiste, un album ou un titre pour le retrouver ici."
          }
        }
      }
    },
