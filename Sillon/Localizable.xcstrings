          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Zhanret do të shfaqen pas një sinkronizimi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los géneros aparecerán tras una sincronización."
          }
        },
        "sr": {
