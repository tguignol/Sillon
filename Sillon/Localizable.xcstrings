    "Glissez les poignées (fréquence ↔, gain ↕). Touchez-en une pour régler sa largeur.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe die Griffe (Frequenz ↔, Verstärkung ↕). Tippe auf einen, um seine Breite einzustellen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascina le maniglie (frequenza ↔, guadagno ↕). Toccane una per regolarne la larghezza."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag the handles (frequency ↔, gain ↕). Tap one to adjust its width."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste os manípulos (frequência ↔, ganho ↕). Toque num para ajustar a largura."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Rrëshqit dorezat (frekuenca ↔, fitimi ↕). Prek njërën për të rregulluar gjerësinë."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra los tiradores (frecuencia ↔, ganancia ↕). Toca uno para ajustar su anchura."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevucite ručice (frekvencija ↔, pojačanje ↕). Dodirnite jednu da podesite njenu širinu."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Trair las manetgas (frequenza ↔, gain ↕). Smacchai sin ina per reglar sia ladezza."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutamaçları sürükleyin (frekans ↔, kazanç ↕). Genişliğini ayarlamak için birine dokunun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez les poignées (fréquence ↔, gain ↕). Touchez-en une pour régler sa largeur."
          }
        }
      }
    },
