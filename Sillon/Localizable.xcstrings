    "0 s conserve l'enchaînement sans blanc (gapless). Au-delà, les morceaux se fondent l'un dans l'autre.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s erhält den nahtlosen Übergang (gapless). Darüber hinaus gehen die Titel ineinander über."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s mantiene la riproduzione senza pause (gapless). Oltre, i brani si fondono l'uno nell'altro."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s keeps playback gapless with no silence. Higher values blend tracks into one another."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s mantém o encadeamento sem pausa (gapless). Acima disso, as músicas fundem-se umas nas outras."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s ruan kalimin pa heshtje (gapless). Më shumë, këngët shkrihen njëra te tjetra."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s mantiene el encadenado sin silencios (gapless). Por encima, las pistas se funden entre sí."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s zadržava neprekidno nizanje bez tišine (gapless). Iznad toga, pesme se stapaju jedna u drugu."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s mantegna la successiun senza pausa (gapless). Plinavant fonda ina chanzun en l'autra."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "0 sn boşluksuz geçişi korur (gapless). Üzerine çıkıldığında parçalar birbirine karışır."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "0 s conserve l'enchaînement sans blanc (gapless). Au-delà, les morceaux se fondent l'un dans l'autre."
          }
        }
      }
    },
