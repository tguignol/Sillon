    "Ajoutez des titres depuis la bibliothèque (appui long sur un titre ▸ Ajouter à une playlist).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge Titel aus der Bibliothek hinzu (langes Tippen auf einen Titel ▸ Zu Playlist hinzufügen)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi brani dalla libreria (tocco prolungato su un brano ▸ Aggiungi a una playlist)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add tracks from the library (long-press a track ▸ Add to Playlist)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione faixas a partir da biblioteca (toque longo numa faixa ▸ Adicionar a uma playlist)."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Shto këngë nga biblioteka (shtyp gjatë mbi një këngë ▸ Shto te një listë këngësh)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade pistas desde la biblioteca (mantén pulsada una pista ▸ Añadir a una lista)."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodajte pesme iz biblioteke (dug pritisak na pesmu ▸ Dodaj na plejlistu)."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Agiuntai tocs ord la biblioteca (smacchar ditg sin in toc ▸ Agiuntar ad ina playlist)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kitaplıktan parça ekleyin (bir parçaya uzun basın ▸ Çalma listesine ekle)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des titres depuis la bibliothèque (appui long sur un titre ▸ Ajouter à une playlist)."
          }
        }
      }
    },
    "Ajoutez un serveur Jellyfin, Navidrome/Subsonic ou un dossier local pour commencer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge einen Jellyfin- oder Navidrome/Subsonic-Server oder einen lokalen Ordner hinzu, um zu beginnen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un server Jellyfin, Navidrome/Subsonic o una cartella locale per iniziare."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a Jellyfin, Navidrome/Subsonic server or a local folder to get started."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione um servidor Jellyfin, Navidrome/Subsonic ou uma pasta local para começar."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Shto një server Jellyfin, Navidrome/Subsonic ose një dosje lokale për të nisur."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un servidor Jellyfin, Navidrome/Subsonic o una carpeta local para empezar."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodajte Jellyfin, Navidrome/Subsonic server ili lokalnu fasciklu da biste počeli."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Agiuntai in server Jellyfin, Navidrome/Subsonic u in register local per cumenzar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Başlamak için bir Jellyfin, Navidrome/Subsonic sunucusu ya da yerel klasör ekleyin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un serveur Jellyfin, Navidrome/Subsonic ou un dossier local pour commencer."
          }
        }
      }
    },
    "Ajoutez un serveur dans Réglages, puis lancez une synchronisation pour retrouver votre musique ici.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge in den Einstellungen einen Server hinzu und starte dann eine Synchronisierung, um deine Musik hier wiederzufinden."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un server in Impostazioni, poi avvia una sincronizzazione per ritrovare qui la tua musica."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a server in Settings, then run a sync to find your music here."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione um servidor nas Definições e depois inicie uma sincronização para encontrar a sua música aqui."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Shto një server te Cilësimet, pastaj nis një sinkronizim që ta gjesh muzikën tënde këtu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un servidor en Ajustes y luego ejecuta una sincronización para encontrar tu música aquí."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodajte server u Podešavanjima, zatim pokrenite sinhronizaciju da biste ovde pronašli svoju muziku."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Agiuntai in server en ils Parameters, lain lura ina sincronisaziun per chattar qua vossa musica."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayarlar'dan bir sunucu ekleyin, ardından müziğinizi burada görmek için eşitleme başlatın."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un serveur dans Réglages, puis lancez une synchronisation pour retrouver votre musique ici."
          }
        }
      }
    },
    "Ajoutez un serveur dans Réglages, puis lancez une synchronisation pour voir votre musique ici.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge in den Einstellungen einen Server hinzu und starte dann eine Synchronisierung, um deine Musik hier zu sehen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un server in Impostazioni, poi avvia una sincronizzazione per vedere qui la tua musica."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a server in Settings, then run a sync to see your music here."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione um servidor nas Definições e depois inicie uma sincronização para ver a sua música aqui."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Shto një server te Cilësimet, pastaj nis një sinkronizim që ta shohësh muzikën tënde këtu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un servidor en Ajustes y luego ejecuta una sincronización para ver tu música aquí."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodajte server u Podešavanjima, zatim pokrenite sinhronizaciju da biste ovde videli svoju muziku."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Agiuntai in server en ils Parameters, lain lura ina sincronisaziun per vesair qua vossa musica."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayarlar'dan bir sunucu ekleyin, ardından müziğinizi burada görmek için eşitleme başlatın."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un serveur dans Réglages, puis lancez une synchronisation pour voir votre musique ici."
          }
        }
      }
    },
