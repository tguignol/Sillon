    "Ajoutez un serveur dans Réglages, puis lancez une synchronisation pour retrouver votre musique ici." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge in den Einstellungen einen Server hinzu und starte dann eine Synchronisierung, um deine Musik hier wiederzufinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add a server in Settings, then run a sync to find your music here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un servidor en Ajustes y luego ejecuta una sincronización para encontrar tu música aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez un serveur dans Réglages, puis lancez une synchronisation pour retrouver votre musique ici."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi un server in Impostazioni, poi avvia una sincronizzazione per ritrovare qui la tua musica."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione um servidor nas Definições e depois inicie uma sincronização para encontrar a sua música aqui."
          }
        },
        "rm" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agiuntai in server en ils Parameters, lain lura ina sincronisaziun per chattar qua vossa musica."
          }
        },
        "sq" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shto një server te Cilësimet, pastaj nis një sinkronizim që ta gjesh muzikën tënde këtu."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodajte server u Podešavanjima, zatim pokrenite sinhronizaciju da biste ovde pronašli svoju muziku."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ayarlar'dan bir sunucu ekleyin, ardından müziğinizi burada görmek için eşitleme başlatın."
          }
        }
      }
    },
