    "Affiche en un seul élément (badge « N sources ») un album ou un titre présent sur plusieurs serveurs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt ein Album oder einen Titel, der auf mehreren Servern vorhanden ist, als einzelnes Element (Badge „N Quellen“) an."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra come un unico elemento (badge «N sorgenti») un album o un brano presente su più server."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows an album or track found on several servers as a single item (a \"N sources\" badge)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra num único elemento (etiqueta «N fontes») um álbum ou faixa presente em vários servidores."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Shfaq si një element të vetëm (shenjë «N burime») një album ose këngë që gjendet në disa serverë."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra como un solo elemento (etiqueta «N fuentes») un álbum o una pista presente en varios servidores."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prikazuje kao jednu stavku (oznaka „N izvora“) album ili pesmu koja postoji na više servera."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Mussa sco in singul element (badge « N funtaunas ») in album u in toc preschent sin plirs servers."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birden çok sunucuda bulunan bir albümü veya parçayı tek bir öğe olarak gösterir (« N kaynak » rozeti)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche en un seul élément (badge « N sources ») un album ou un titre présent sur plusieurs serveurs."
          }
        }
      }
    },
