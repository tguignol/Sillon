          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yazılıyor…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Écriture…"
          }
        }
      }
    },
    "Égalise le volume perçu d'une piste à l'autre (mode Piste) ou conserve la dynamique d'un album (mode Album). Le limiteur anti-saturation évite l'écrêtage quand le gain est positif.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gleicht die wahrgenommene Lautstärke von Titel zu Titel an (Modus Titel) oder erhält die Dynamik eines Albums (Modus Album). Der Übersteuerungsbegrenzer verhindert Clipping bei positiver Verstärkung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Uniforma il volume percepito da una traccia all'altra (modalità Traccia) o conserva la dinamica di un album (modalità Album). Il limitatore anti-saturazione evita la distorsione quando il guadagno è positivo."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Evens out perceived volume from one track to the next (Track mode) or preserves an album's dynamics (Album mode). The clipping limiter prevents distortion when the gain is positive."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Iguala o volume percecionado entre faixas (modo Faixa) ou preserva a dinâmica de um álbum (modo Álbum). O limitador anti-saturação evita o corte quando o ganho é positivo."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Barazon volumin e perceptuar nga një këngë te tjetra (mënyra Kënga) ose ruan dinamikën e një albumi (mënyra Album). Kufizuesi kundër ngopjes shmang prerjen kur fitimi është pozitiv."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iguala el volumen percibido de una pista a otra (modo Pista) o conserva la dinámica de un álbum (modo Álbum). El limitador antisaturación evita el recorte cuando la ganancia es positiva."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izjednačava percipiranu jačinu zvuka od numere do numere (režim Numera) ili zadržava dinamiku albuma (režim Album). Limiter protiv izobličenja sprečava odsecanje kada je pojačanje pozitivno."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Egualisescha il volum percepì dad in toc a l'auter (modus Toc) u mantegna la dinamica d'in album (modus Album). Il limitader cunter saturaziun evitescha la sclippada cura ch'il gain è positiv."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Algılanan ses düzeyini parçadan parçaya eşitler (Parça modu) ya da bir albümün dinamiğini korur (Albüm modu). Doygunluk önleyici sınırlayıcı, kazanç pozitifken kırpılmayı önler."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Égalise le volume perçu d'une piste à l'autre (mode Piste) ou conserve la dynamique d'un album (mode Album). Le limiteur anti-saturation évite l'écrêtage quand le gain est positif."
          }
        }
      }
    },
