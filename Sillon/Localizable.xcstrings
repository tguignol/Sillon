    "Accès au dossier refusé par le système.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordnerzugriff vom System verweigert."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso alla cartella negato dal sistema."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Folder access denied by the system."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesso à pasta recusado pelo sistema."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Qasja te dosja u refuzua nga sistemi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema denegó el acceso a la carpeta."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem je odbio pristup fascikli."
          }
        },
        "rm": {
