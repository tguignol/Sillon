    "Artistes, albums et titres dans toute votre bibliothèque, tous serveurs confondus.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Interpreten, Alben und Titel aus deiner gesamten Bibliothek, über alle Server hinweg."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Artisti, album e brani in tutta la tua libreria, su tutti i server."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Artists, albums and tracks across your whole library, all servers combined."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Artistas, álbuns e faixas em toda a sua biblioteca, em todos os servidores."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Artistë, albume dhe këngë në gjithë bibliotekën tënde, në të gjithë serverët."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Artistas, álbumes y pistas en toda tu biblioteca, en todos los servidores."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvođači, albumi i pesme u celoj vašoj biblioteci, na svim serverima."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Artists, albums e tocs en tut vossa biblioteca, sin tut ils servers."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm sunucular dahil, kitaplığınızdaki sanatçılar, albümler ve parçalar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Artistes, albums et titres dans toute votre bibliothèque, tous serveurs confondus."
          }
        }
      }
    },
