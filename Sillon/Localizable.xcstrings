    "Créez une playlist avec le bouton +, ou ajoutez des titres depuis la bibliothèque (appui long sur un titre).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle eine Playlist mit der Taste + oder füge Titel aus der Bibliothek hinzu (langes Tippen auf einen Titel)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea una playlist con il pulsante +, oppure aggiungi brani dalla libreria (tocco prolungato su un brano)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a playlist with the + button, or add tracks from the library (long-press a track)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie uma playlist com o botão +, ou adicione faixas a partir da biblioteca (toque longo numa faixa)."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Krijo një listë këngësh me butonin +, ose shto këngë nga biblioteka (shtyp gjatë mbi një këngë)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea una lista con el botón +, o añade pistas desde la biblioteca (mantén pulsada una pista)."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Napravite plejlistu dugmetom +, ili dodajte pesme iz biblioteke (dug pritisak na pesmu)."
          }
        },
        "rm": {
          "stringUnit": {
            "state": "translated",
            "value": "Creai ina playlist cun il buttun +, u agiuntai tocs ord la biblioteca (smacchar ditg sin in toc)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "+ düğmesiyle bir çalma listesi oluşturun ya da kitaplıktan parça ekleyin (bir parçaya uzun basın)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez une playlist avec le bouton +, ou ajoutez des titres depuis la bibliothèque (appui long sur un titre)."
          }
        }
      }
    },
